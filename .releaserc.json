{
  "branches": [
    "main"
  ],
  "preset": "conventionalcommits",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],
    [
      "semantic-release-replace-plugin",
      {
        "replacements": [
          {
            "files": [
              "django_slackbot/__init__.py"
            ],
            "from": "__version__ = \".*\"",
            "to": "__version__ = \"${nextRelease.version}\"",
            "results": [
              {
                "file": "django_slackbot/__init__.py",
                "hasChanged": true,
                "numMatches": 1,
                "numReplacements": 1
              }
            ],
            "countMatches": true
          },
          {
            "files": [
              "pyproject.toml"
            ],
            "from": "^version = \".*\"",
            "to": "version = \"${nextRelease.version}\"",
            "results": [
              {
                "file": "pyproject.toml",
                "hasChanged": true,
                "numMatches": 1,
                "numReplacements": 1
              }
            ],
            "countMatches": true
          },
          {
            "files": [
              "Dockerfile"
            ],
            "from": "Version=\".*\"",
            "to": "Version=\"${nextRelease.version}\"",
            "results": [
              {
                "file": "Dockerfile",
                "hasChanged": true,
                "numMatches": 1,
                "numReplacements": 1
              }
            ],
            "countMatches": true
          }
        ]
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "uv build",
        "publishCmd": "docker buildx imagetools create -t ghcr.io/bubblehouse/django-slackbot:${nextRelease.version} -t ghcr.io/bubblehouse/django-slackbot:latest ghcr.io/bubblehouse/django-slackbot:sha-$IMAGE_SHA-amd64 ghcr.io/bubblehouse/django-slackbot:sha-$IMAGE_SHA-arm64"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "Dockerfile",
          "django_slackbot/__init__.py",
          "pyproject.toml",
          "package.json",
          "package-lock.json",
          "CHANGELOG.md"
        ]
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "dist/django_bubblehouse_slackbot-*.whl",
            "label": "Python wheel"
          },
          {
            "path": "dist/django_bubblehouse_slackbot-*.tar.gz",
            "label": "Source distribution"
          }
        ]
      }
    ]
  ]
}
